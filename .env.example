# ===== Application =====
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-long-random-string-min-32-chars
APP_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO
AUDIT_DEBUG_DATA=false

# ===== Database =====
POSTGRES_USER=adaudit
POSTGRES_PASSWORD=changeme
POSTGRES_DB=adaudit
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://adaudit:changeme@postgres:5432/adaudit

# ===== Neo4j =====
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ===== Auth =====
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== Seed admin =====
SEED_ADMIN_EMAIL=admin@adauditai.local
SEED_ADMIN_PASSWORD=ChangeMeNow!2026
SEED_ADMIN_NAME=Administrateur

# ===== LLM provider =====
# Options: anthropic | openai | azure | ollama | mock
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-5
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2000
LLM_BATCH_SIZE=5
LLM_MAX_RETRIES=3
LLM_TIMEOUT_SECONDS=60

# Anthropic
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Google Gemini (OpenAI-compatible endpoint)
GOOGLE_API_KEY=

# OpenRouter (free open-source models + paid)
OPENROUTER_API_KEY=

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Ollama (local)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b

# ===== Report =====
REPORT_FOOTER_TEXT=CONFIDENTIEL — Document de travail
REPORT_BRAND_NAME=AD Audit AI
